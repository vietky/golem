# Environment variables for CI/CD Pipeline
# Copy this file to .env and fill in your actual values

# Jenkins Configuration
JENKINS_URL=http://157.66.101.66:8080
JENKINS_USER=admin
JENKINS_TOKEN=
JENKINS_JOB_NAME=golem-century-deploy

# Jenkins Home
JENKINS_HOME=/var/jenkins_home

# Repositories Directory (host path where repos/code will be mounted)
# Jenkins will access this at /opt/jenkins_home/repos (read-write)
JENKINS_REPOS_DIR=/opt/jenkins/repos
JENKINS_DEPLOY_DIR=/opt/jenkins_deploy

# Application Configuration
APP_NAME=golem-century
APP_DIR=${JENKINS_REPOS_DIR}/golem
APP_PORT=8081
GIT_REPO=https://github.com/vietky/golem.git
GIT_BRANCH=main

# Ansible Configuration (for manual deployment)
ANSIBLE_HOST=157.66.101.66
ANSIBLE_USER=root
ANSIBLE_SSH_KEY=~/.ssh/id_rsa

# Optional: Slack/Discord notifications (future enhancement)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8080
HOST=0.0.0.0

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10

# Redis Persistence
REDIS_ENABLE_AOF=true
REDIS_AOF_FSYNC=everysec
REDIS_ENABLE_RDB=true
REDIS_RDB_SAVE_INTERVAL=900

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=golem_user
POSTGRES_PASSWORD=golem_password
POSTGRES_DB=golem_db
POSTGRES_SSL_MODE=disable
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_MAX_IDLE_CONNECTIONS=5
POSTGRES_CONNECTION_MAX_LIFETIME=3600

# ============================================================================
# Game Configuration
# ============================================================================
GAME_MAX_SESSIONS=100
GAME_SESSION_TIMEOUT=3600
GAME_CLEANUP_INTERVAL=300

# ============================================================================
# WebSocket Configuration
# ============================================================================
WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024
WS_WRITE_DEADLINE=10

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=development